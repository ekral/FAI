@page "/Create"
@using UTB.Library.Contracts
@using UTB.Library.Web.FormModels
@inject LibraryService LibraryService
@inject NavigationManager NavigationManager

<h3>Create Author</h3>

<EditForm FormName="AuthorForm" Model="Model" OnValidSubmit="Submit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="nameInput" class="form-label">Name</label>
        <InputText class="form-control" id="nameInput" aria-describedby="Name" @bind-Value="Model!.Name" />
    </div>
    <div class="mb-3">
        <button type="submit" class="btn btn-success">Submit</button>
    </div>

</EditForm>

@code {
    [SupplyParameterFromForm]
    private AuthorFormData? Model { get; set; }

    protected override void OnInitialized() => Model ??= new();

    private async Task Submit()
    {
        if (Model is not null && Model.Name is not null)
        {
            AuthorRequestDto requestDto = new(Model.Name);

            await LibraryService.CreateAuthorAsync(requestDto);

            NavigationManager.NavigateTo("/authors");
        }
    }
}

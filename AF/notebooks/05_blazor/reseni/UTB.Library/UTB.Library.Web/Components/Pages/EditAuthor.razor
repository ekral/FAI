@page "/edit/{AuthorId:int}"
@using UTB.Library.Contracts
@using UTB.Library.Web.FormModels
@inject LibraryService LibraryService
@inject NavigationManager NavigationManager

<h3>Edit Author</h3>

@if (Model is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <EditForm FormName="EditAuthorForm" Model="Model" OnValidSubmit="Submit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="nameInput" class="form-label">Name</label>
            <InputText class="form-control" id="nameInput" aria-describedby="Name" @bind-Value="Model.Name" />
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-success">Save</button>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public int AuthorId { get; set; }

    [SupplyParameterFromForm]
    private AuthorFormData? Model { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        if (Model is null)
        {
            AuthorDto? author = await LibraryService.GetAuthorByIdAsync(AuthorId);

            if (author is null)
            {
                NavigationManager.NavigateTo("/authors");
                return;
            }

            Model = new AuthorFormData
            {
                Name = author.Name
            };
        }
    }

    private async Task Submit()
    {
        if (Model is not null && Model.Name is not null)
        {
            AuthorRequestDto authorRequestDto = new(Model.Name);

            await LibraryService.UpdateAuthorAsync(AuthorId, authorRequestDto);

            NavigationManager.NavigateTo("/authors");
        }
    }
}

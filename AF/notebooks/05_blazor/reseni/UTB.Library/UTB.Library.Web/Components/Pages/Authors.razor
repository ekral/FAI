@page "/authors"
@rendermode InteractiveServer
@using UTB.Library.Contracts
@attribute [StreamRendering]
@inject LibraryService LibraryService

<PageTitle>Authors</PageTitle>

<h1>Authors</h1>

<p>This component demonstrates calling web api.</p>

<button class="btn btn-primary" @onclick="Create">New Author</button>

@if (authors == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var author in authors)
            {
                <tr>
                    <td>@author.Id</td>
                    <td>@author.Name</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private AuthorDto[]? authors;

    protected override async Task OnInitializedAsync()
    {
        authors = await LibraryService.GetAuthorsAsync();
    }

    private async Task Create()
    {
        await LibraryService.CreateAuthorAsync();

        authors = await LibraryService.GetAuthorsAsync();
    }
}

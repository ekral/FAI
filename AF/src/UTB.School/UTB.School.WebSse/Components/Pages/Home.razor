@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Net.ServerSentEvents
@using System.Text.Json
@using UTB.School.Contracts
@implements IAsyncDisposable
@inject IHttpClientFactory ClientFactory

<PageTitle>SseDemo</PageTitle>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<h1>Last Added Student</h1>


@if (!string.IsNullOrWhiteSpace(message))
{
    <p>@message</p>
}

@code {

    private CancellationTokenSource cts = new();
    private string? errorMessage;
    private string? message;

    protected override void OnInitialized()
    {
        _ = StartSseAsync(cts.Token);
    }

    private async Task StartSseAsync(CancellationToken ct)
    {
        var client = ClientFactory.CreateClient("webapi");

        try
        {
            using var response = await client.GetAsync("/stream", HttpCompletionOption.ResponseHeadersRead, ct);

            response.EnsureSuccessStatusCode();

            using var stream = await response.Content.ReadAsStreamAsync(ct);

            SseParser<string> parser = SseParser.Create(stream);

            await foreach (SseItem<string> sseEvent in parser.EnumerateAsync(ct))
            {
                if (sseEvent.EventType == "init")
                {
                    continue;
                }

                StudentDto? student = JsonSerializer.Deserialize<StudentDto>(sseEvent.Data, new JsonSerializerOptions() { PropertyNameCaseInsensitive = true });

                if (student is null)
                {
                    continue;
                }

                message = $"{student.Id}: {student.Name} Active: {student.IsActive}";

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "API is not available.";
        }
        catch (OperationCanceledException)
        {
            // Ignorovat při zavření komponenty
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        cts.Cancel();
        cts.Dispose();
    }

}

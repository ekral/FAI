@page "/students"
@using UTB.School.Contracts
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject SchoolService SchoolService

<PageTitle>Students</PageTitle>

<h1>Students</h1>

<p>This component demonstrates showing students.</p>

<a class="btn btn-primary" href="/createstudent">Create</a>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (students == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in students)
            {
                <tr>
                    <td>@student.Id</td>
                    <td>@student.Name</td>
                    <td>@student.IsActive</td>
                    <td><button @onclick="@(() => Delete(student.Id))">Delete</button></td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private StudentDto[]? students;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudentsAsync();
    }

    private async Task Delete(int studentId)
    {
        var result = await SchoolService.DeleteStudentAsync(studentId);

        if (result.IsT0)
        {
            await LoadStudentsAsync();
        }
        else
        {
            errorMessage = result.AsT1;
        }
    }

    protected async Task LoadStudentsAsync()
    {
        var result = await SchoolService.GetStudentsAsync();

        if (result.IsT0)
        {
            students = result.AsT0;
            errorMessage = null;
        }
        else
        {
            students = [];
            errorMessage = result.AsT1;
        }
    }
}
